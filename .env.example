# ============================================
# EIFA COUTURE — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your Supabase project
# credentials (Project Settings → API in the Supabase dashboard).
#
# Both variables below are NEXT_PUBLIC_* because the anon key is
# designed to be exposed to the browser — it is safe by design as
# long as Row Level Security (RLS) policies are configured on every
# table. Never put the Supabase `service_role` key behind a
# NEXT_PUBLIC_* variable; it must only ever be used in trusted
# server-only contexts, and is not needed for this auth foundation.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ============================================
# Razorpay — server-side only, never NEXT_PUBLIC_*
# ============================================
# Key id IS safe client-side (used by Razorpay Checkout.js in the
# browser), so it's the one exception that's intentionally public.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Service-role key — bypasses RLS. Server-only. Get from Supabase
# dashboard → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=
